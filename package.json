{
  "name": "json-drop",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "NODE_ENV=development bun --hot index.ts",
    "start": "bun index.ts",
    "migrate": "bun migrate.ts",
    "codegen": "bun run codegen.ts",
    "build:frontend": "bun build frontend/index.html --outdir frontend/dist --minify && cp -r frontend/public/* frontend/dist/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "test": "bun test"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "kysely-codegen": "^0.20.0",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "axios": "^1.17.0",
    "hono": "^4.12.25",
    "jose": "^6.2.3",
    "kysely": "^0.29.2",
    "kysely-bun-dialects": "^1.0.0",
    "preact": "^10.29.2",
    "short-uuid": "^6.0.3"
  }
}
